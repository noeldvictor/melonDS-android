<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto">

    <me.magnum.melonds.ui.settings.preferences.InGameLockedListPreference
            android:key="video_renderer"
            android:title="@string/renderer"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/video_renderer_options"
            android:entryValues="@array/video_renderer_values"
            android:defaultValue="software"/>

    <me.magnum.melonds.ui.settings.preferences.InGameLockedListPreference
            android:key="video_internal_resolution"
            android:title="@string/internal_resolution"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/video_internal_resolution_options"
            android:entryValues="@array/video_internal_resolution_values"
            android:defaultValue="1"/>

    <SwitchPreference
            android:key="enable_threaded_rendering"
            android:title="@string/threaded_rendering"
            android:summary="@string/threaded_rendering_summary"
            app:iconSpaceReserved="false"
            android:defaultValue="true" />

    <me.magnum.melonds.ui.settings.preferences.InGameLockedListPreference
            android:key="video_filtering"
            android:title="@string/filter"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/video_filtering_options"
            android:entryValues="@array/video_filtering_values"
            android:defaultValue="none"/>

    <ListPreference
            android:key="video_hd_texture_filter"
            android:title="@string/hd_texture_filter"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/hd_filter_mode_options"
            android:entryValues="@array/hd_filter_mode_values"
            android:defaultValue="0"/>

    <ListPreference
            android:key="video_obj_sprite_filter"
            android:title="@string/obj_sprite_filter"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/hd_filter_mode_options"
            android:entryValues="@array/hd_filter_mode_values"
            android:defaultValue="0"/>

    <ListPreference
            android:key="video_bg_layer_filter"
            android:title="@string/bg_layer_filter"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/hd_filter_mode_options"
            android:entryValues="@array/hd_filter_mode_values"
            android:defaultValue="0"/>

    <SwitchPreference
            android:key="enable_texture_packs"
            android:title="@string/load_texture_packs"
            android:summary="@string/load_texture_packs_summary"
            app:iconSpaceReserved="false"
            android:defaultValue="false" />

    <SwitchPreference
            android:key="enable_texture_dumping"
            android:title="@string/dump_textures"
            android:summary="@string/dump_textures_summary"
            app:iconSpaceReserved="false"
            android:defaultValue="false" />

    <SwitchPreference
            android:key="enable_filter_disk_cache"
            android:title="@string/filter_disk_cache"
            android:summary="@string/filter_disk_cache_summary"
            app:iconSpaceReserved="false"
            android:defaultValue="true" />

    <me.magnum.melonds.ui.settings.preferences.StoragePickerPreference
            android:key="video_retroarch_shader_root"
            android:title="@string/video_retroarch_shader_root_title"
            android:summary="@string/video_retroarch_shader_root_summary"
            app:iconSpaceReserved="false"
            app:type="directory"
            app:permissions="read"
            app:persistPermissions="true" />

    <ListPreference
            android:key="video_retroarch_shader_preset"
            android:title="@string/video_retroarch_shader_preset_title"
            android:summary="@string/video_retroarch_shader_preset_summary"
            app:iconSpaceReserved="false" />

    <EditTextPreference
            android:key="video_retroarch_shader_parameters"
            android:title="@string/video_retroarch_shader_parameters_title"
            android:summary="@string/video_retroarch_shader_parameters_summary"
            app:iconSpaceReserved="false" />

    <SwitchPreference
            android:key="video_retroarch_shader_clear_history"
            android:title="@string/video_retroarch_shader_clear_history_title"
            android:summary="@string/video_retroarch_shader_clear_history_summary"
            app:iconSpaceReserved="false"
            android:defaultValue="false" />

    <Preference
            android:key="dual_screen_presets"
            android:title="@string/dual_screen_presets_settings_title"
            app:iconSpaceReserved="false" />

    <ListPreference
            android:key="external_display_mode"
            android:title="@string/external_display_mode"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/external_display_mode_options"
            android:entryValues="@array/external_display_mode_values"
            android:defaultValue="melon_dual_ds" />

    <ListPreference
            android:key="fps_counter_position"
            android:title="@string/fps_counter_position"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/fps_counter_position_options"
            android:entryValues="@array/fps_counter_position_values"
            android:defaultValue="hidden" />

    <ListPreference
            android:key="dsi_camera_source"
            android:title="@string/dsi_camera_source"
            android:summary="%s"
            app:iconSpaceReserved="false"
            android:entries="@array/dsi_camera_source_options"
            android:entryValues="@array/dsi_camera_source_values"
            android:defaultValue="physical_cameras" />

    <me.magnum.melonds.ui.settings.preferences.StoragePickerPreference
            android:key="dsi_camera_static_image"
            android:title="@string/dsi_camera_image"
            android:dependency="dsi_camera_source"
            app:iconSpaceReserved="false"
            app:type="file"
            app:permissions="read"
            app:persistPermissions="true"
            app:mimeType="image/jpeg|image/png" />

    <PreferenceCategory
            android:key="video_vulkan_driver_category"
            android:title="@string/video_vulkan_driver_category"
            app:iconSpaceReserved="false">

        <ListPreference
                android:key="video_vulkan_driver_mode"
                android:title="@string/video_vulkan_driver_mode"
                android:summary="%s"
                app:iconSpaceReserved="false"
                android:entries="@array/video_vulkan_driver_mode_options"
                android:entryValues="@array/video_vulkan_driver_mode_values"
                android:defaultValue="system" />

        <Preference
                android:key="video_vulkan_driver_import"
                android:title="@string/video_vulkan_driver_import"
                android:summary="@string/video_vulkan_driver_import_summary"
                app:iconSpaceReserved="false" />

        <Preference
                android:key="video_vulkan_driver_remove"
                android:title="@string/video_vulkan_driver_remove"
                android:summary="@string/video_vulkan_driver_remove_summary"
                app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
            android:key="video_hacks_category"
            android:title="@string/video_hacks"
            app:iconSpaceReserved="false">

        <SwitchPreference
                android:key="video_renderer_debug_tools_enabled"
                android:title="@string/video_renderer_debug_tools_enabled"
                android:summary="@string/video_renderer_debug_tools_enabled_summary"
                app:iconSpaceReserved="false"
                android:defaultValue="false" />

        <SwitchPreference
                android:key="video_renderer_debug_bgobj_enabled"
                android:title="@string/video_renderer_debug_bgobj_enabled"
                android:summary="@string/video_renderer_debug_bgobj_enabled_summary"
                android:dependency="video_renderer_debug_tools_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="false" />

        <SwitchPreference
                android:key="video_renderer_debug_latch_trace_enabled"
                android:title="@string/video_renderer_debug_latch_trace_enabled"
                android:summary="@string/video_renderer_debug_latch_trace_enabled_summary"
                android:dependency="video_renderer_debug_tools_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="false" />

        <SwitchPreference
                android:key="video_renderer_debug_filter_tint_enabled"
                android:title="@string/video_renderer_debug_filter_tint_enabled"
                android:summary="@string/video_renderer_debug_filter_tint_enabled_summary"
                android:dependency="video_renderer_debug_tools_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="false" />

        <SwitchPreference
                android:key="video_conservative_coverage_enabled"
                android:title="@string/conservative_coverage_enabled"
                android:summary="@string/conservative_coverage_enabled_summary"
                app:iconSpaceReserved="false"
                android:defaultValue="false" />

        <SeekBarPreference
                android:key="video_conservative_coverage_px"
                android:title="@string/conservative_coverage_px"
                android:summary="@string/conservative_coverage_px_summary"
                android:dependency="video_conservative_coverage_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="150"
                app:min="0"
                android:max="200"
                app:showSeekBarValue="true" />

        <SwitchPreference
                android:key="video_conservative_coverage_apply_repeat"
                android:title="@string/conservative_coverage_apply_repeat"
                android:summary="@string/conservative_coverage_apply_repeat_summary"
                android:dependency="video_conservative_coverage_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="true" />

        <SwitchPreference
                android:key="video_conservative_coverage_apply_clamp"
                android:title="@string/conservative_coverage_apply_clamp"
                android:summary="@string/conservative_coverage_apply_clamp_summary"
                android:dependency="video_conservative_coverage_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="false" />

        <SeekBarPreference
                android:key="video_conservative_coverage_depth_bias"
                android:title="@string/conservative_coverage_depth_bias"
                android:summary="@string/conservative_coverage_depth_bias_summary"
                android:dependency="video_conservative_coverage_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="0"
                app:min="0"
                android:max="2000"
                app:showSeekBarValue="true" />

        <SwitchPreference
                android:key="video_debug_3d_clear_magenta"
                android:title="@string/debug_3d_clear_magenta"
                android:summary="@string/debug_3d_clear_magenta_summary"
                android:dependency="video_renderer_debug_tools_enabled"
                app:iconSpaceReserved="false"
                android:defaultValue="false" />

    </PreferenceCategory>
</PreferenceScreen>
