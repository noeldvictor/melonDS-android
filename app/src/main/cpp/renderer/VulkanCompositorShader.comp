Rgba6 sampleCapture3DColorAtDsPixel(int dsX, int dsY)
{
    Rgba6 zero;
    zero.r = 0;
    zero.g = 0;
    zero.b = 0;
    zero.a = 0;

    if (pc.captureSourceValid == 0u
        || dsX < 0
        || dsX >= 256
        || dsY < 0
        || dsY >= 192)
        return zero;

    return unpackColor6(capture3dPacked[uint(dsY) * 256u + uint(dsX)]);
}

uint readTopPacked(int y, int x)
{
    uint offset = uint(y) * pc.packedStride + uint(x);
    return topPacked[offset];
}

uint readBottomPacked(int y, int x)
{
    uint offset = uint(y) * pc.packedStride + uint(x);
    return bottomPacked[offset];
}

#define DEFINE_SAMPLE_FILTERED_PACKED_LAYER(FUNC_NAME, READ_PACKED_FN) \
Rgba6 FUNC_NAME(int sourceX, int dsY, int scaledX, int scaledY, uint safeScale, int layerOffset, int displayMode) \
{ \
    Rgba6 nearest = unpackColor6(READ_PACKED_FN(dsY, layerOffset + sourceX)); \
    if (safeScale <= 1u) \
        return nearest; \
    uint heavyMode = displayMode == 1 ? packedHeavyFilterMode(nearest) : 0u; \
    if ((OBJ_FILTER_MODE >= 3u || BG_FILTER_MODE >= 3u) && heavyMode >= 3u) \
    { \
        int xm = max(sourceX - 1, 0); \
        int xp = min(sourceX + 1, 255); \
        int ym = max(dsY - 1, 0); \
        int yp = min(dsY + 1, 191); \
        vec4 e = packedFilterTapColor(nearest, nearest); \
        vec4 b = packedFilterTapColor(unpackColor6(READ_PACKED_FN(ym, layerOffset + sourceX)), nearest); \
        vec4 d = packedFilterTapColor(unpackColor6(READ_PACKED_FN(dsY, layerOffset + xm)), nearest); \
        vec4 f = packedFilterTapColor(unpackColor6(READ_PACKED_FN(dsY, layerOffset + xp)), nearest); \
        vec4 h = packedFilterTapColor(unpackColor6(READ_PACKED_FN(yp, layerOffset + sourceX)), nearest); \
        /* flat neighborhoods (most pixels) skip the per-corner filter math */ \
        if (ColorDistance(e, b) + ColorDistance(e, d) \
            + ColorDistance(e, f) + ColorDistance(e, h) < (2.0 / 255.0)) \
            return nearest; \
        vec4 a = packedFilterTapColor(unpackColor6(READ_PACKED_FN(ym, layerOffset + xm)), nearest); \
        vec4 c = packedFilterTapColor(unpackColor6(READ_PACKED_FN(ym, layerOffset + xp)), nearest); \
        vec4 g = packedFilterTapColor(unpackColor6(READ_PACKED_FN(yp, layerOffset + xm)), nearest); \
        vec4 px_i = packedFilterTapColor(unpackColor6(READ_PACKED_FN(yp, layerOffset + xp)), nearest); \
        vec2 subpos = ((vec2(float(scaledX), float(scaledY)) \
            - (vec2(float(sourceX), float(dsY)) * float(safeScale))) \
            + vec2(0.5)) / float(safeScale); \
        vec4 filtered = HeavyFilterTexel(a, b, c, d, e, f, g, h, px_i, subpos, safeScale, heavyMode); \
        return vec3ToColor6(clamp(filtered.rgb, vec3(0.0), vec3(1.0)) * 63.0, nearest.a); \
    } \
    bool producerSmooth = (filterModeUsed(1u) || filterModeUsed(2u)) \
        && (heavyMode == 1u || heavyMode == 2u); \
    if (!producerSmooth && pc.filtering != kFilterLinear) \
        return nearest; \
    float dsXFloat = (float(scaledX) + 0.5) / float(safeScale) - 0.5; \
    float dsYFloat = (float(scaledY) + 0.5) / float(safeScale) - 0.5; \
    int x0 = int(floor(clamp(dsXFloat, 0.0, 255.0))); \
    int y0 = int(floor(clamp(dsYFloat, 0.0, 191.0))); \
    int x1 = min(x0 + 1, 255); \
    int y1 = min(y0 + 1, 191); \
    float tx = clamp(dsXFloat - float(x0), 0.0, 1.0); \
    float ty = clamp(dsYFloat - float(y0), 0.0, 1.0); \
    if (filterModeUsed(2u) && heavyMode == 2u) \
    { \
        tx = tx * tx * (3.0 - (2.0 * tx)); \
        ty = ty * ty * (3.0 - (2.0 * ty)); \
    } \
    Rgba6 c00 = unpackColor6(READ_PACKED_FN(y0, layerOffset + x0)); \
    Rgba6 c10 = unpackColor6(READ_PACKED_FN(y0, layerOffset + x1)); \
    Rgba6 c01 = unpackColor6(READ_PACKED_FN(y1, layerOffset + x0)); \
    Rgba6 c11 = unpackColor6(READ_PACKED_FN(y1, layerOffset + x1)); \
    if (packedTapIsUnsafeFor2DFilter(c00) \
        || packedTapIsUnsafeFor2DFilter(c10) \
        || packedTapIsUnsafeFor2DFilter(c01) \
        || packedTapIsUnsafeFor2DFilter(c11)) \
        return nearest; \
    vec3 v00 = color6ToVec3(c00); \
    vec3 v10 = color6ToVec3(c10); \
    vec3 v01 = color6ToVec3(c01); \
    vec3 v11 = color6ToVec3(c11); \
    vec3 blended = mix(mix(v00, v10, tx), mix(v01, v11, tx), ty); \
    if (pc.filtering == kFilterLinear || producerSmooth) \
        return vec3ToColor6(blended, nearest.a); \
    vec3 sharpened = mix(blended, color6ToVec3(nearest), 0.45); \
    vec3 minColor = min(min(v00, v10), min(v01, v11)); \
    vec3 maxColor = max(max(v00, v10), max(v01, v11)); \
    return vec3ToColor6(clamp(sharpened, minColor, maxColor), nearest.a); \
}

DEFINE_SAMPLE_FILTERED_PACKED_LAYER(sampleTopFilteredPackedLayer, readTopPacked)
DEFINE_SAMPLE_FILTERED_PACKED_LAYER(sampleBottomFilteredPackedLayer, readBottomPacked)

#undef DEFINE_SAMPLE_FILTERED_PACKED_LAYER

#define DEFINE_COMPOSE_SCREEN_PIXEL(FUNC_NAME, READ_PACKED_FN, SCREEN_IS_TOP) \
Rgba6 FUNC_NAME(int sourceX, int dsY, int scaledX, int scaledY, uint safeScale) \
{ \
    uint masterBrightness = READ_PACKED_FN(dsY, 256 * 3); \
    int displayMode = int((masterBrightness >> 16u) & 0x3u); \
    int brightnessMode = int(((masterBrightness >> 8u) & 0xFFu) >> 6u); \
    int brightnessFactor = min(16, int(masterBrightness & 0x1Fu)); \
    int xOffset = int((masterBrightness >> 24u) & 0xFFu) \
        - ((((masterBrightness >> 16u) & 0x80u) != 0u) ? 256 : 0); \
    bool regularCaptureUses3d = (masterBrightness & kMetaFlagRegularCaptureUses3d) != 0u; \
    bool vramCaptureUses3d = (masterBrightness & kMetaFlagVramCaptureUses3d) != 0u; \
    bool forceLive3dCompMode7 = (masterBrightness & kMetaFlagForceLive3dCompMode7) != 0u; \
    bool structuredAboveDominant = (masterBrightness & kMetaFlagStructuredAboveDominant) != 0u; \
    bool compMode2StructuredPair = (masterBrightness & kMetaFlagCompMode2StructuredPair) != 0u; \
    bool screenOwnsLive3D = SCREEN_IS_TOP ? (pc.liveSourceScreenSwap != 0u) : (pc.liveSourceScreenSwap == 0u); \
    bool structuredHandoffNoCurrent3D = SCREEN_IS_TOP ? (pc.topStructuredHandoffNoCurrent3d != 0u) : (pc.bottomStructuredHandoffNoCurrent3d != 0u); \
    bool oppositeStructuredHandoffNoCurrent3D = SCREEN_IS_TOP ? (pc.bottomStructuredHandoffNoCurrent3d != 0u) : (pc.topStructuredHandoffNoCurrent3d != 0u); \
    bool structuredHandoffSuppress3D = SCREEN_IS_TOP ? (pc.topStructuredHandoffSuppress3d != 0u) : (pc.bottomStructuredHandoffSuppress3d != 0u); \
    bool screenMatchesCapture3DSource = pc.captureSourceScreenSwapValid == 0u \
        || (SCREEN_IS_TOP ? (pc.captureSourceScreenSwap != 0u) : (pc.captureSourceScreenSwap == 0u)); \
	    Rgba6 pixel = SCREEN_IS_TOP \
            ? sampleTopFilteredPackedLayer(sourceX, dsY, scaledX, scaledY, safeScale, 0, displayMode) \
            : sampleBottomFilteredPackedLayer(sourceX, dsY, scaledX, scaledY, safeScale, 0, displayMode); \
	    Rgba6 nearestPixel = unpackColor6(READ_PACKED_FN(dsY, sourceX)); \
	    if (displayMode == 1) \
	    { \
	        Rgba6 val1 = pixel; \
	        Rgba6 val2 = SCREEN_IS_TOP \
                ? sampleTopFilteredPackedLayer(sourceX, dsY, scaledX, scaledY, safeScale, 256, displayMode) \
                : sampleBottomFilteredPackedLayer(sourceX, dsY, scaledX, scaledY, safeScale, 256, displayMode); \
        Rgba6 val3 = unpackColor6(READ_PACKED_FN(dsY, 512 + sourceX)); \
        int compMode = val3.a & 0xF; \
        bool structured2DSlot = hasStructured2D3DSlot(val3); \
        bool structured2DAbove = hasStructured2DAbovePlane(val3); \
        bool structured2DProtectedBlack = hasStructured2DProtectedBlack(val3); \
        bool structured2DNo3DCoverage = hasStructured2DNo3DCoverage(val3); \
        bool structured2DOnly = isStructured2DOnly(val3); \
        bool both3dPlaceholders = isPacked3dPlaceholder(val1) && isPacked3dPlaceholder(val2); \
        bool captureBackedComp4 = compMode == 4 && both3dPlaceholders; \
        bool packedPlaneHas3DLayerSlot = isPacked3dLayerSlot(val1) || isPacked3dLayerSlot(val2); \
        bool screenHasPrevious3D = SCREEN_IS_TOP ? (pc.previousTopSourceValid != 0u) : (pc.previousBottomSourceValid != 0u); \
        Rgba6 comp4ProbeTopVal1 = unpackColor6(READ_PACKED_FN(8, 128)); \
        Rgba6 comp4ProbeTopVal2 = unpackColor6(READ_PACKED_FN(8, 256 + 128)); \
        Rgba6 comp4ProbeTopControl = unpackColor6(READ_PACKED_FN(8, 512 + 128)); \
        uint topProbeMeta = READ_PACKED_FN(8, 256 * 3); \
        Rgba6 comp4ProbeMiddleVal1 = unpackColor6(READ_PACKED_FN(96, 128)); \
        Rgba6 comp4ProbeMiddleVal2 = unpackColor6(READ_PACKED_FN(96, 256 + 128)); \
        Rgba6 comp4ProbeMiddleControl = unpackColor6(READ_PACKED_FN(96, 512 + 128)); \
        uint middleProbeMeta = READ_PACKED_FN(96, 256 * 3); \
        Rgba6 comp4ProbeBottomVal1 = unpackColor6(READ_PACKED_FN(184, 128)); \
        Rgba6 comp4ProbeBottomVal2 = unpackColor6(READ_PACKED_FN(184, 256 + 128)); \
        Rgba6 comp4ProbeBottomControl = unpackColor6(READ_PACKED_FN(184, 512 + 128)); \
        uint bottomProbeMeta = READ_PACKED_FN(184, 256 * 3); \
        bool topProbeCaptureBackedComp4 = ((comp4ProbeTopControl.a & 0xF) == 4) \
            && isPacked3dPlaceholder(comp4ProbeTopVal1) \
            && isPacked3dPlaceholder(comp4ProbeTopVal2); \
        bool middleProbeCaptureBackedComp4 = ((comp4ProbeMiddleControl.a & 0xF) == 4) \
            && isPacked3dPlaceholder(comp4ProbeMiddleVal1) \
            && isPacked3dPlaceholder(comp4ProbeMiddleVal2); \
        bool bottomProbeCaptureBackedComp4 = ((comp4ProbeBottomControl.a & 0xF) == 4) \
            && isPacked3dPlaceholder(comp4ProbeBottomVal1) \
            && isPacked3dPlaceholder(comp4ProbeBottomVal2); \
        bool screenWideCaptureBackedComp4 = topProbeCaptureBackedComp4 \
            && middleProbeCaptureBackedComp4 \
            && bottomProbeCaptureBackedComp4; \
        bool partialCaptureBackedComp4Screen = (topProbeCaptureBackedComp4 \
                || middleProbeCaptureBackedComp4 \
                || bottomProbeCaptureBackedComp4) \
            && !screenWideCaptureBackedComp4; \
        bool topProbeRegularCaptureUses3d = (topProbeMeta & kMetaFlagRegularCaptureUses3d) != 0u; \
        bool middleProbeRegularCaptureUses3d = (middleProbeMeta & kMetaFlagRegularCaptureUses3d) != 0u; \
        bool bottomProbeRegularCaptureUses3d = (bottomProbeMeta & kMetaFlagRegularCaptureUses3d) != 0u; \
        bool screenHasPartialRegularCapture3d = (topProbeRegularCaptureUses3d \
                || middleProbeRegularCaptureUses3d \
                || bottomProbeRegularCaptureUses3d) \
            && !(topProbeRegularCaptureUses3d \
                && middleProbeRegularCaptureUses3d \
                && bottomProbeRegularCaptureUses3d); \
        bool partialCaptureBackedComp4BorderLine = partialCaptureBackedComp4Screen \
            && screenHasPartialRegularCapture3d \
            && ((SCREEN_IS_TOP && dsY <= 20) \
                || (!SCREEN_IS_TOP && dsY >= 171)); \
        bool partialRegularCaptureOppositeFringeLine = screenHasPartialRegularCapture3d \
            && !regularCaptureUses3d \
            && ((SCREEN_IS_TOP && dsY >= 171) \
                || (!SCREEN_IS_TOP && dsY <= 20)); \
        bool screenWideRegularCaptureBlank = regularCaptureUses3d \
            && isRegularCaptureBlankPixel(comp4ProbeTopVal1) \
            && isRegularCaptureBlankPixel(comp4ProbeMiddleVal1) \
            && isRegularCaptureBlankPixel(comp4ProbeBottomVal1); \
        bool temporalCompMode7Uses3D = compMode == 7 \
            && (regularCaptureUses3d || forceLive3dCompMode7 || partialRegularCaptureOppositeFringeLine); \
        bool compModeSamples3D = !structured2DOnly \
            && (compMode <= 4 || temporalCompMode7Uses3D || structured2DSlot); \
        int shiftedScaledX = scaledX + (xOffset * int(safeScale)); \
        Rgba6 pixel3D; \
        pixel3D.r = 0; \
        pixel3D.g = 0; \
        pixel3D.b = 0; \
        pixel3D.a = 0; \
        bool pixel3DFromLive = false; \
        if (compModeSamples3D && screenOwnsLive3D) \
        { \
            pixel3D = sample3DColorAtScaledPixel(shiftedScaledX, scaledY); \
            pixel3DFromLive = true; \
        } \
        else if (compModeSamples3D && screenHasPrevious3D) \
            pixel3D = SCREEN_IS_TOP \
                ? samplePreviousTop3DColorAtScaledPixel(shiftedScaledX, scaledY) \
                : samplePreviousBottom3DColorAtScaledPixel(shiftedScaledX, scaledY); \
        if (structured2DNo3DCoverage) \
        { \
            pixel3D.r = 0; \
            pixel3D.g = 0; \
            pixel3D.b = 0; \
            pixel3D.a = 0; \
        } \
        if (regularCaptureUses3d \
            && structuredAboveDominant \
            && compMode == 2 \
            && structured2DSlot \
            && screenHasPrevious3D) \
        { \
            pixel3D = SCREEN_IS_TOP \
                ? samplePreviousTop3DColorAtScaledPixel(shiftedScaledX, scaledY) \
                : samplePreviousBottom3DColorAtScaledPixel(shiftedScaledX, scaledY); \
            pixel3DFromLive = false; \
        } \
        if (compModeSamples3D \
            && screenOwnsLive3D \
            && screenHasPrevious3D \
            && brightnessMode == 0 \
            && !structured2DProtectedBlack \
            && !partialCaptureBackedComp4BorderLine \
            && !regularCaptureUses3d \
            && (structured2DSlot || regularCaptureUses3d || vramCaptureUses3d) \
            && (pixel3D.a & 0x1F) > 0 \
            && ((pixel3D.r | pixel3D.g | pixel3D.b) == 0)) \
        { \
