#version 450

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

// Per-producer 2D filter modes are specialization constants so the
// driver drops every unused filter path at pipeline creation; some
// mobile shader compilers cannot hold all fourteen modes live at once.
layout(constant_id = 0) const uint OBJ_FILTER_MODE = 0u;
layout(constant_id = 1) const uint BG_FILTER_MODE = 0u;

bool filterModeUsed(uint mode)
{
    return OBJ_FILTER_MODE == mode || BG_FILTER_MODE == mode;
}

layout(set = 0, binding = 0, rgba8) uniform writeonly image2D outImage;
layout(set = 0, binding = 1, rgba8) uniform readonly image2D image3dInput;
layout(set = 0, binding = 4, rgba8) uniform readonly image2D image3dPreviousTopInput;
layout(set = 0, binding = 6, rgba8) uniform readonly image2D image3dPreviousBottomInput;

layout(set = 0, binding = 2, std430) readonly buffer TopPackedBuffer
{
    uint topPacked[];
};

layout(set = 0, binding = 3, std430) readonly buffer BottomPackedBuffer
{
    uint bottomPacked[];
};

layout(set = 0, binding = 5, std430) readonly buffer Capture3dBuffer
{
    uint capture3dPacked[];
};

layout(push_constant) uniform PushConsts
{
    uint outputWidth;
    uint outputHeight;
    uint scale;
    uint rendererWidth;
    uint rendererHeight;
    uint packedStride;
    uint screenSwap;
    uint filtering;
    uint previousTopSourceValid;
    uint previousBottomSourceValid;
    uint captureSourceValid;
    uint captureSourceScreenSwapValid;
    uint captureSourceScreenSwap;
    uint liveSourceScreenSwap;
    uint class4VramStructuredPair;
    uint class4NoAboveVramStructuredPair;
    uint class4PreservePackedVramValid;
    uint class4PreservePackedVramScreenSwap;
    uint topStructuredHandoffNoCurrent3d;
    uint bottomStructuredHandoffNoCurrent3d;
    uint topStructuredHandoffSuppress3d;
    uint bottomStructuredHandoffSuppress3d;
} pc;

const uint kMetaFlagRegularCaptureUses3d = 1u << 21u;
const uint kMetaFlagVramCaptureUses3d = 1u << 22u;
const uint kMetaFlagForceLive3dCompMode7 = 1u << 18u;
const uint kMetaFlagStructuredAboveDominant = 1u << 19u;
const uint kMetaFlagCompMode2StructuredPair = 1u << 20u;
const uint kFilterLinear = 1u;

struct Rgba6
{
    int r;
    int g;
    int b;
    int a;
};

bool isPacked3dPlaceholder(Rgba6 color)
{
    return color.r == 0
        && color.g == 0
        && color.b == 0
        && color.a == 0x20;
}

bool isPacked3dLayerSlot(Rgba6 color)
{
    return color.a == 0x40;
}

bool hasPackedVisibleColor(Rgba6 color)
{
    return !isPacked3dPlaceholder(color)
        && ((color.r | color.g | color.b) != 0);
}

bool isRegularCaptureBlankPixel(Rgba6 color)
{
    return isPacked3dPlaceholder(color)
        || (!isPacked3dLayerSlot(color)
            && color.a != 0
            && ((color.r | color.g | color.b) == 0));
}

bool hasStructured2D3DSlot(Rgba6 control)
{
    return (control.a & 0x40) != 0;
}

bool hasStructured2DAbovePlane(Rgba6 control)
{
    return (control.a & 0x80) != 0;
}

bool hasStructured2DProtectedBlack(Rgba6 control)
{
    return (control.a & 0x20) != 0;
}

bool hasStructured2DNo3DCoverage(Rgba6 control)
{
    return (control.a & 0x10) != 0;
}

bool isStructured2DOnly(Rgba6 control)
{
    return !hasStructured2D3DSlot(control)
        && hasStructured2DAbovePlane(control);
}

bool isStructured2DVisible(Rgba6 color)
{
    return color.a != 0
        && !isPacked3dPlaceholder(color)
        && !isPacked3dLayerSlot(color);
}

bool rgbClose6(Rgba6 a, Rgba6 b, int tolerance)
{
    return abs(a.r - b.r) <= tolerance
        && abs(a.g - b.g) <= tolerance
        && abs(a.b - b.b) <= tolerance;
}

int clampColor6(int value);

vec3 color6ToVec3(Rgba6 color)
{
    return vec3(float(color.r), float(color.g), float(color.b));
}

Rgba6 vec3ToColor6(vec3 color, int alpha)
{
    Rgba6 result;
    result.r = clampColor6(int(floor(color.r + 0.5)));
    result.g = clampColor6(int(floor(color.g + 0.5)));
    result.b = clampColor6(int(floor(color.b + 0.5)));
    result.a = alpha;
    return result;
}

bool packedTapIsUnsafeFor2DFilter(Rgba6 color)
{
    return isPacked3dPlaceholder(color) || isPacked3dLayerSlot(color);
}

// Per-producer 2D filter library operating on normalized rgb colors
// (alpha fixed at 1.0; the packed alpha byte is a flag byte and is kept
// from the nearest sample). Modes match the HD texture filter numbering:
// 1 linear, 2 smoothstep, 3 Scale2x, 4 HQ2x lite, 5 2xSaI lite,
// 6 SuperEagle lite, 7 MMPX lite, 8 Anime4K lite, 9 Super2xSaI strong,
// 10 SuperEagle smooth, 11 crisp gradient, 12 crisp edge AA,
// 13 ScaleFX lite.
float ColorDistance(vec4 a, vec4 b)
{
    vec4 delta = abs(a - b);
    return max(max(delta.r, delta.g), max(delta.b, delta.a));
}

bool Similar(vec4 a, vec4 b)
{
    return ColorDistance(a, b) < (1.5 / 255.0);
}

bool SoftSimilar(vec4 a, vec4 b)
{
    return ColorDistance(a, b) < (24.0 / 255.0);
}

bool IsThinContrastDetail(vec4 e, vec4 b, vec4 d, vec4 f, vec4 h)
{
    if (e.a <= 0.01)
        return false;

    int support = 0;
    support += Similar(e, b) ? 1 : 0;
    support += Similar(e, d) ? 1 : 0;
    support += Similar(e, f) ? 1 : 0;
    support += Similar(e, h) ? 1 : 0;

    float farthest = max(max(ColorDistance(e, b), ColorDistance(e, d)),
                         max(ColorDistance(e, f), ColorDistance(e, h)));
    return support <= 2 && farthest > (48.0 / 255.0);
}

vec4 ProtectThinDetail(vec4 candidate, vec4 b, vec4 d, vec4 e, vec4 f, vec4 h)
{
    if (IsThinContrastDetail(e, b, d, f, h) &&
        ColorDistance(candidate, e) > (8.0 / 255.0))
        return e;
    return candidate;
}

vec4 Scale2xTexel(vec4 b, vec4 d, vec4 e, vec4 f, vec4 h, ivec2 subpixel)
{
    if (Similar(b, h) || Similar(d, f))
        return e;

    if (all(equal(subpixel, ivec2(0, 0))))
        return Similar(d, b) ? d : e;
    if (all(equal(subpixel, ivec2(1, 0))))
        return Similar(b, f) ? f : e;
    if (all(equal(subpixel, ivec2(0, 1))))
        return Similar(d, h) ? d : e;
    return Similar(h, f) ? f : e;
}

vec4 HQ2xLiteTexel(vec4 b, vec4 d, vec4 e, vec4 f, vec4 h, ivec2 subpixel)
{
    vec4 scaled = Scale2xTexel(b, d, e, f, h, subpixel);
    if (Similar(e, scaled))
        return e;

    vec4 cardinal = (b + d + f + h) * 0.25;
    float edge = max(ColorDistance(b, h), ColorDistance(d, f));
    float weight = clamp(edge * 3.0, 0.0, 0.65);
    return ProtectThinDetail(mix(mix(e, scaled, 0.65), cardinal, weight * 0.35),
                             b, d, e, f, h);
}

vec4 TwoXSaILiteTexel(vec4 b, vec4 d, vec4 e, vec4 f, vec4 h, ivec2 subpixel)
{
    vec4 corner = e;
    if (all(equal(subpixel, ivec2(0, 0))))
        corner = (Similar(d, b) && !Similar(d, h) && !Similar(b, f)) ? ((d + b) * 0.5) : e;
    else if (all(equal(subpixel, ivec2(1, 0))))
        corner = (Similar(b, f) && !Similar(b, d) && !Similar(f, h)) ? ((b + f) * 0.5) : e;
    else if (all(equal(subpixel, ivec2(0, 1))))
        corner = (Similar(d, h) && !Similar(d, b) && !Similar(h, f)) ? ((d + h) * 0.5) : e;
    else
        corner = (Similar(h, f) && !Similar(h, d) && !Similar(f, b)) ? ((h + f) * 0.5) : e;

    return ProtectThinDetail(mix(e, corner, 0.75), b, d, e, f, h);
}

vec4 SuperEagleCorner(vec4 e, vec4 edge0, vec4 edge1, vec4 diagonal, vec4 opposite0, vec4 opposite1)
{
    if (Similar(edge0, edge1) && !Similar(opposite0, opposite1))
        return mix(e, (edge0 + edge1) * 0.5, 0.88);
    if (Similar(edge0, diagonal) && Similar(edge1, diagonal))
        return mix(e, diagonal, 0.78);
    if (Similar(edge0, edge1))
        return mix(e, (edge0 + edge1) * 0.5, 0.55);
    return e;
}

vec4 SuperEagleLiteTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    vec4 tl = SuperEagleCorner(e, d, b, a, f, h);
    vec4 tr = SuperEagleCorner(e, b, f, c, d, h);
    vec4 bl = SuperEagleCorner(e, d, h, g, b, f);
    vec4 br = SuperEagleCorner(e, h, f, px_i, d, b);

    bool diagonal_down = Similar(a, px_i) && !Similar(c, g);
    bool diagonal_up = Similar(c, g) && !Similar(a, px_i);
    if (diagonal_down)
    {
        tl = mix(tl, a, 0.45);
        br = mix(br, px_i, 0.45);
    }
    else if (diagonal_up)
    {
        tr = mix(tr, c, 0.45);
        bl = mix(bl, g, 0.45);
    }

    vec4 corner;
    if (all(equal(subpixel, ivec2(0, 0))))
        corner = tl;
    else if (all(equal(subpixel, ivec2(1, 0))))
        corner = tr;
    else if (all(equal(subpixel, ivec2(0, 1))))
        corner = bl;
    else
        corner = br;

    if (Similar(corner, e))
    {
        bool vertical = Similar(b, h);
        bool horizontal = Similar(d, f);
        if (vertical && !horizontal)
            corner = mix(e, (b + h) * 0.5, 0.18);
        else if (horizontal && !vertical)
            corner = mix(e, (d + f) * 0.5, 0.18);
    }

    return ProtectThinDetail(corner, b, d, e, f, h);
}

vec4 MMPXLiteCorner(vec4 e, vec4 edge0, vec4 edge1, vec4 diagonal, vec4 opposite0, vec4 opposite1)
{
    if (SoftSimilar(edge0, edge1) && !SoftSimilar(opposite0, opposite1))
        return mix(e, (edge0 + edge1) * 0.5, 0.92);
    if (SoftSimilar(edge0, diagonal) && SoftSimilar(edge1, diagonal))
        return mix(e, diagonal, 0.84);
    if (SoftSimilar(edge0, diagonal) && !SoftSimilar(edge1, opposite1))
        return mix(e, edge0, 0.72);
    if (SoftSimilar(edge1, diagonal) && !SoftSimilar(edge0, opposite0))
        return mix(e, edge1, 0.72);
    if (SoftSimilar(edge0, edge1))
        return mix(e, (edge0 + edge1) * 0.5, 0.62);
    return e;
}

vec4 MMPXLiteTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    vec4 tl = MMPXLiteCorner(e, d, b, a, f, h);
    vec4 tr = MMPXLiteCorner(e, b, f, c, d, h);
    vec4 bl = MMPXLiteCorner(e, d, h, g, b, f);
    vec4 br = MMPXLiteCorner(e, h, f, px_i, d, b);

    bool diagonal_down = SoftSimilar(a, px_i) && !SoftSimilar(c, g);
    bool diagonal_up = SoftSimilar(c, g) && !SoftSimilar(a, px_i);
    if (diagonal_down)
    {
        tl = mix(tl, a, 0.35);
        br = mix(br, px_i, 0.35);
    }
    else if (diagonal_up)
    {
        tr = mix(tr, c, 0.35);
        bl = mix(bl, g, 0.35);
    }

    vec4 corner;
    if (all(equal(subpixel, ivec2(0, 0))))
        corner = tl;
    else if (all(equal(subpixel, ivec2(1, 0))))
        corner = tr;
    else if (all(equal(subpixel, ivec2(0, 1))))
        corner = bl;
    else
        corner = br;

    vec4 cardinal = (b + d + f + h) * 0.25;
    float flatness = min(ColorDistance(b, h), ColorDistance(d, f));
    float smoothWeight = 0.18 * (1.0 - smoothstep(8.0 / 255.0, 64.0 / 255.0, flatness));
    return ProtectThinDetail(mix(corner, cardinal, smoothWeight), b, d, e, f, h);
}

vec4 Anime4KLiteTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    vec4 base = MMPXLiteTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (IsThinContrastDetail(e, b, d, f, h))
        return ProtectThinDetail(base, b, d, e, f, h);

    vec4 cardinal = (b + d + f + h) * 0.25;
    vec4 pair = (d + f) * 0.5;
    float pairDist = ColorDistance(d, f);
    float verticalDist = ColorDistance(b, h);
    if (verticalDist < pairDist)
    {
        pair = (b + h) * 0.5;
        pairDist = verticalDist;
    }

    float diagDownDist = ColorDistance(a, px_i);
    if (diagDownDist < pairDist)
    {
        pair = (a + px_i) * 0.5;
        pairDist = diagDownDist;
    }

    float diagUpDist = ColorDistance(c, g);
    if (diagUpDist < pairDist)
        pair = (c + g) * 0.5;

    float contrast = max(max(ColorDistance(e, b), ColorDistance(e, d)),
                         max(ColorDistance(e, f), ColorDistance(e, h)));
    float edgeWeight = smoothstep(4.0 / 255.0, 56.0 / 255.0, contrast);
    vec4 smoothed = mix(base, pair, edgeWeight * 0.72);
    vec4 sharpened = smoothed + ((smoothed - cardinal) * (edgeWeight * 0.30));
    return ProtectThinDetail(clamp(sharpened, vec4(0.0), vec4(1.0)), b, d, e, f, h);
}

vec4 SuperSAIStrongCorner(vec4 e, vec4 edge0, vec4 edge1, vec4 diagonal, vec4 opposite0, vec4 opposite1)
{
    float pairDist = ColorDistance(edge0, edge1);
    float oppositeDist = ColorDistance(opposite0, opposite1);
    float diag0 = ColorDistance(edge0, diagonal);
    float diag1 = ColorDistance(edge1, diagonal);

    if (pairDist < (40.0 / 255.0) && oppositeDist > (pairDist + (10.0 / 255.0)))
        return mix(e, (edge0 + edge1) * 0.5, 0.96);
    if (max(diag0, diag1) < (42.0 / 255.0))
        return mix(e, diagonal, 0.92);
    if (diag0 < (36.0 / 255.0) && ColorDistance(edge1, opposite1) > (diag0 + (8.0 / 255.0)))
        return mix(e, edge0, 0.86);
    if (diag1 < (36.0 / 255.0) && ColorDistance(edge0, opposite0) > (diag1 + (8.0 / 255.0)))
        return mix(e, edge1, 0.86);
    if (pairDist < (56.0 / 255.0))
        return mix(e, (edge0 + edge1) * 0.5, 0.74);
    return e;
}

vec4 SuperSAIStrongTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    vec4 tl = SuperSAIStrongCorner(e, d, b, a, f, h);
    vec4 tr = SuperSAIStrongCorner(e, b, f, c, d, h);
    vec4 bl = SuperSAIStrongCorner(e, d, h, g, b, f);
    vec4 br = SuperSAIStrongCorner(e, h, f, px_i, d, b);

    bool diagonalDown = ColorDistance(a, px_i) < (ColorDistance(c, g) + (8.0 / 255.0));
    bool diagonalUp = ColorDistance(c, g) < (ColorDistance(a, px_i) + (8.0 / 255.0));
    if (diagonalDown && !diagonalUp)
    {
        tl = mix(tl, a, 0.50);
        br = mix(br, px_i, 0.50);
    }
    else if (diagonalUp && !diagonalDown)
    {
        tr = mix(tr, c, 0.50);
        bl = mix(bl, g, 0.50);
    }

    vec4 corner;
    if (all(equal(subpixel, ivec2(0, 0))))
        corner = tl;
    else if (all(equal(subpixel, ivec2(1, 0))))
        corner = tr;
    else if (all(equal(subpixel, ivec2(0, 1))))
        corner = bl;
    else
        corner = br;

    if (Similar(corner, e))
    {
        float horizontal = ColorDistance(d, f);
        float vertical = ColorDistance(b, h);
        float contrast = max(max(ColorDistance(e, b), ColorDistance(e, d)),
                             max(ColorDistance(e, f), ColorDistance(e, h)));
        float weight = smoothstep(6.0 / 255.0, 80.0 / 255.0, contrast) * 0.32;
        corner = (horizontal < vertical)
            ? mix(e, (d + f) * 0.5, weight)
            : mix(e, (b + h) * 0.5, weight);
    }

    corner.a = e.a;
    return clamp(corner, vec4(0.0), vec4(1.0));
}

vec4 SuperEagleSmoothTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    vec4 eagle = SuperEagleLiteTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    vec4 sai = SuperSAIStrongTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    vec4 guide = mix(eagle, sai, 0.62);

    vec4 neighborhood = (a + b + c + d + e + f + g + h + px_i) * (1.0 / 9.0);
    vec4 cardinal = (b + d + f + h) * 0.25;
    vec4 pair = (d + f) * 0.5;
    float pairDist = ColorDistance(d, f);

    float verticalDist = ColorDistance(b, h);
    if (verticalDist < pairDist)
    {
        pair = (b + h) * 0.5;
        pairDist = verticalDist;
    }

    float diagDownDist = ColorDistance(a, px_i);
    if (diagDownDist < pairDist)
    {
        pair = (a + px_i) * 0.5;
        pairDist = diagDownDist;
    }

    float diagUpDist = ColorDistance(c, g);
    if (diagUpDist < pairDist)
        pair = (c + g) * 0.5;

    float contrast = max(max(ColorDistance(e, b), ColorDistance(e, d)),
                         max(ColorDistance(e, f), ColorDistance(e, h)));
    float smoothWeight = mix(0.56, 0.94, smoothstep(2.0 / 255.0, 64.0 / 255.0, contrast));
    vec4 soft = mix(mix(neighborhood, pair, 0.38), cardinal, 0.25);
    vec4 smoothed = mix(guide, soft, smoothWeight);
    smoothed.a = e.a;
    return clamp(smoothed, vec4(0.0), vec4(1.0));
}

vec4 CrispGradientTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    vec4 anime = Anime4KLiteTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    vec4 sai = SuperSAIStrongTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    vec4 guide = mix(anime, sai, 0.38);

    vec4 neighborhood = (a + b + c + d + e + f + g + h + px_i) * (1.0 / 9.0);
    vec4 cardinal = (b + d + f + h) * 0.25;
    vec4 reference = mix(neighborhood, cardinal, 0.35);

    float contrast = max(max(ColorDistance(e, b), ColorDistance(e, d)),
                         max(ColorDistance(e, f), ColorDistance(e, h)));
    float edgeWeight = smoothstep(3.0 / 255.0, 72.0 / 255.0, contrast);
    vec4 crisp = guide + ((guide - reference) * mix(0.20, 0.62, edgeWeight));
    crisp = mix(crisp, e, 0.10 * (1.0 - edgeWeight));
    crisp.a = e.a;
    return ProtectThinDetail(clamp(crisp, vec4(0.0), vec4(1.0)), b, d, e, f, h);
}

vec4 CrispEdgeAATexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    vec4 base = CrispGradientTexel(a, b, c, d, e, f, g, h, px_i, subpixel);

    bool right = subpixel.x != 0;
    bool down = subpixel.y != 0;
    vec4 xNeighbor = right ? f : d;
    vec4 yNeighbor = down ? h : b;
    vec4 diagonal = right ? (down ? px_i : c) : (down ? g : a);
    vec4 xSupport0 = right ? c : a;
    vec4 xSupport1 = right ? px_i : g;
    vec4 ySupport0 = down ? g : a;
    vec4 ySupport1 = down ? px_i : c;

    float xWeight = smoothstep(18.0 / 255.0, 92.0 / 255.0, ColorDistance(e, xNeighbor));
    float yWeight = smoothstep(18.0 / 255.0, 92.0 / 255.0, ColorDistance(e, yNeighbor));
    float xSupport = (SoftSimilar(xNeighbor, xSupport0) ? 1.0 : 0.0) +
                     (SoftSimilar(xNeighbor, xSupport1) ? 1.0 : 0.0);
    float ySupport = (SoftSimilar(yNeighbor, ySupport0) ? 1.0 : 0.0) +
                     (SoftSimilar(yNeighbor, ySupport1) ? 1.0 : 0.0);
    xWeight *= mix(0.60, 1.0, xSupport * 0.5);
    yWeight *= mix(0.60, 1.0, ySupport * 0.5);

    vec4 edge = mix(base, xNeighbor, xWeight * 0.28);
    edge = mix(edge, yNeighbor, yWeight * 0.28);

    float diagonalSupport = (SoftSimilar(diagonal, xNeighbor) ? 1.0 : 0.0) +
                            (SoftSimilar(diagonal, yNeighbor) ? 1.0 : 0.0);
    float diagonalWeight = smoothstep(22.0 / 255.0, 110.0 / 255.0, ColorDistance(e, diagonal)) *
                           diagonalSupport * 0.14;
    edge = mix(edge, diagonal, diagonalWeight);

    float maxEdge = max(max(xWeight, yWeight), diagonalWeight * 2.0);
    vec4 reference = mix((b + d + f + h) * 0.25, e, 0.31);
    vec4 crisp = edge + ((edge - reference) * mix(0.07, 0.25, maxEdge));
    crisp.a = e.a;
    return ProtectThinDetail(clamp(crisp, vec4(0.0), vec4(1.0)), b, d, e, f, h);
}

// ScaleFX lite (mode 13): single-pass approximation of Sp00kyFox's ScaleFX.
// It evaluates the pass-1 junction corner strength for the quadrant touching
// this subpixel, applies the pass-2 corner dominance rule against the
// opposing junction corner, then blends along the detected diagonal using
// the pass-2 orientation metric.
float ScaleFXLiteStrength(vec4 center, vec4 nx, vec4 ny, vec4 diag)
{
    float d = ColorDistance(nx, ny);
    float ax = ColorDistance(center, nx);
    float ay = ColorDistance(center, ny);
    float bx = ColorDistance(diag, ny);
    float by = ColorDistance(diag, nx);
    float diff = ax - ay;
    float wght1 = max(0.5 - d, 0.0) * 2.0;
    float dir = (min(ax, bx) + ax > min(ay, by) + ay) ? diff : -diff;
    float wght2 = clamp((1.0 - d) + dir, 0.0, 1.0);
    return wght1 * wght2 * ax * ay;
}

vec4 ScaleFXLiteTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel)
{
    bool right = subpixel.x != 0;
    bool down = subpixel.y != 0;
    vec4 xNeighbor = right ? f : d;
    vec4 yNeighbor = down ? h : b;
    vec4 diagonal = right ? (down ? px_i : c) : (down ? g : a);

    float ownStrength = ScaleFXLiteStrength(e, xNeighbor, yNeighbor, diagonal);
    float rivalStrength = ScaleFXLiteStrength(diagonal, xNeighbor, yNeighbor, e);
    if (ownStrength <= rivalStrength)
        return e;

    float ax = ColorDistance(e, xNeighbor);
    float ay = ColorDistance(e, yNeighbor);
    float horiCost = min(ax, ColorDistance(diagonal, yNeighbor)) + ax;
    float vertCost = min(ay, ColorDistance(diagonal, xNeighbor)) + ay;
    vec4 slope = (horiCost > vertCost) ? yNeighbor : xNeighbor;

    float weight = smoothstep(0.01, 0.14, ownStrength - rivalStrength);
    vec4 blended = mix(e, slope, weight);
    return ProtectThinDetail(clamp(blended, vec4(0.0), vec4(1.0)), b, d, e, f, h);
}

ivec2 HeavyFilterQuadrant(vec2 subpos)
{
    return ivec2(subpos.x >= 0.5 ? 1 : 0,
                 subpos.y >= 0.5 ? 1 : 0);
}

vec4 HeavyFilterCorner(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, ivec2 subpixel, uint mode)
{
    if (filterModeUsed(4u) && mode == 4u)
        return HQ2xLiteTexel(b, d, e, f, h, subpixel);
    if (filterModeUsed(5u) && mode == 5u)
        return TwoXSaILiteTexel(b, d, e, f, h, subpixel);
    if (filterModeUsed(6u) && mode == 6u)
        return SuperEagleLiteTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(7u) && mode == 7u)
        return MMPXLiteTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(8u) && mode == 8u)
        return Anime4KLiteTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(9u) && mode == 9u)
        return SuperSAIStrongTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(10u) && mode == 10u)
        return SuperEagleSmoothTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(11u) && mode == 11u)
        return CrispGradientTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(12u) && mode == 12u)
        return CrispEdgeAATexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(13u) && mode == 13u)
        return ScaleFXLiteTexel(a, b, c, d, e, f, g, h, px_i, subpixel);
    if (filterModeUsed(3u))
        return Scale2xTexel(b, d, e, f, h, subpixel);
    return e;
}

vec4 HeavyFilterTexel(vec4 a, vec4 b, vec4 c, vec4 d, vec4 e, vec4 f, vec4 g, vec4 h, vec4 px_i, vec2 subpos, uint scale, uint mode)
{
    if (scale <= 1u)
        return e;
    if (scale <= 2u)
        return HeavyFilterCorner(a, b, c, d, e, f, g, h, px_i, HeavyFilterQuadrant(subpos), mode);

    vec4 tl = HeavyFilterCorner(a, b, c, d, e, f, g, h, px_i, ivec2(0, 0), mode);
    vec4 tr = HeavyFilterCorner(a, b, c, d, e, f, g, h, px_i, ivec2(1, 0), mode);
    vec4 bl = HeavyFilterCorner(a, b, c, d, e, f, g, h, px_i, ivec2(0, 1), mode);
    vec4 br = HeavyFilterCorner(a, b, c, d, e, f, g, h, px_i, ivec2(1, 1), mode);
    vec2 weight = subpos * subpos * (vec2(3.0) - (vec2(2.0) * subpos));
    return mix(mix(tl, tr, weight.x), mix(bl, br, weight.x), weight.y);
}

// The packed plane alpha byte carries the winning producer of each pixel:
// bits 0..3 BG0..BG3, bit 4 OBJ, bit 5 backdrop, bit 6 the 3D layer slot and
// bit 7 semi-transparent OBJ. Pick the user filter mode by producer; 3D
// pixels (composed at high resolution elsewhere) are never filtered here.
uint packedHeavyFilterMode(Rgba6 color)
{
    if ((color.a & 0x40) != 0)
        return 0u;
    if (isPacked3dPlaceholder(color))
        return 0u;
    if ((color.a & 0x90) != 0)
        return OBJ_FILTER_MODE;
    if ((color.a & 0x2F) != 0)
        return BG_FILTER_MODE;
    return 0u;
}

vec4 packedFilterTapColor(Rgba6 tap, Rgba6 center)
{
    Rgba6 source = packedTapIsUnsafeFor2DFilter(tap) ? center : tap;
    return vec4(color6ToVec3(source) * (1.0 / 63.0), 1.0);
}

Rgba6 makeScreenWhite()
{
    Rgba6 color;
    color.r = 63;
    color.g = 63;
    color.b = 63;
    color.a = 0;
    return color;
}

int clampColor6(int value)
{
    return clamp(value, 0, 63);
}

int toColor8(int value6)
{
    int base = clampColor6(value6) << 2;
    return base | (base >> 6);
}

Rgba6 unpackColor6(uint packedColor)
{
    Rgba6 color;
    color.r = int(packedColor & 0xFFu);
    color.g = int((packedColor >> 8u) & 0xFFu);
    color.b = int((packedColor >> 16u) & 0xFFu);
    color.a = int((packedColor >> 24u) & 0xFFu);
    return color;
}

void applyBrightnessUp(inout Rgba6 color, int evy)
{
    color.r = clampColor6(color.r + (((63 - color.r) * evy) >> 4));
    color.g = clampColor6(color.g + (((63 - color.g) * evy) >> 4));
    color.b = clampColor6(color.b + (((63 - color.b) * evy) >> 4));
}

void applyBrightnessDown(inout Rgba6 color, int evy, int roundingBias)
{
    color.r = clampColor6(color.r - (((color.r * evy) + roundingBias) >> 4));
    color.g = clampColor6(color.g - (((color.g * evy) + roundingBias) >> 4));
    color.b = clampColor6(color.b - (((color.b * evy) + roundingBias) >> 4));
}

Rgba6 sample3DColorAtScaledPixel(int scaledX, int scaledY)
{
    Rgba6 zero;
    zero.r = 0;
    zero.g = 0;
    zero.b = 0;
    zero.a = 0;

    if (scaledX < 0
        || scaledX >= int(pc.rendererWidth)
        || scaledY < 0
        || scaledY >= int(pc.rendererHeight))
        return zero;

    vec4 color3d = imageLoad(image3dInput, ivec2(scaledX, scaledY));

    Rgba6 color;
    color.r = int(clamp(color3d.r * 255.0 + 0.5, 0.0, 255.0)) >> 2;
    color.g = int(clamp(color3d.g * 255.0 + 0.5, 0.0, 255.0)) >> 2;
    color.b = int(clamp(color3d.b * 255.0 + 0.5, 0.0, 255.0)) >> 2;
    color.a = int(clamp(color3d.a * 255.0 + 0.5, 0.0, 255.0)) >> 3;
    return color;
}

bool hasVisibleLive3DSupportAtScaledPixel(int scaledX, int scaledY, int step)
{
    for (int dy = -1; dy <= 1; dy++)
    {
        for (int dx = -1; dx <= 1; dx++)
        {
            if (dx == 0 && dy == 0)
                continue;
            Rgba6 neighbor = sample3DColorAtScaledPixel(
                scaledX + (dx * step),
                scaledY + (dy * step));
            if ((neighbor.a & 0x1F) > 0
                && ((neighbor.r | neighbor.g | neighbor.b) != 0))
                return true;
        }
    }
    return false;
}

